{
  "name": "naruto-online-launcher",
  "version": "2.0.0",
  "description": "Ultra-optimized Flash game launcher for Naruto Online - No tracking, no ads, full GPU acceleration",
  "main": "src/main.js",
  "author": "Chrispsz",
  "license": "MIT",
  "homepage": "https://github.com/Chrispsz/naruto-online-launcher#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Chrispsz/naruto-online-launcher.git"
  },
  "bugs": {
    "url": "https://github.com/Chrispsz/naruto-online-launcher/issues"
  },
  "keywords": [
    "naruto",
    "naruto-online",
    "flash",
    "launcher",
    "game",
    "electron",
    "ppapi"
  ],
  "engines": {
    "node": ">=12.0.0"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux AppImage --win portable",
    "build:linux": "electron-builder --linux AppImage",
    "build:win": "electron-builder --win portable",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "electron": "11.5.0",
    "electron-builder": "22.14.13",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0"
  },
  "dependencies": {},
  "build": {
    "appId": "com.naruto.launcher",
    "productName": "Naruto Online",
    "npmRebuild": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*.js"
    ],
    "extraResources": [
      {
        "from": "flash",
        "to": "flash",
        "filter": ["*.so", "*.dll"]
      },
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      }
    ],
    "asar": true,
    "compression": "maximum",
    "linux": {
      "target": ["AppImage"],
      "category": "Game",
      "executableName": "naruto-online",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "executableName": "NarutoOnline",
      "icon": "assets/icon.ico"
    },
    "electronVersion": "11.5.0"
  }
}
